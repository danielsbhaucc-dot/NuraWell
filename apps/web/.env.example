# Copy to .env.local in this folder (apps/web) — Next.js only auto-loads env from the app directory.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-or-leave-empty>

# Production: set to your real origin (e.g. https://your-app.vercel.app or custom domain) so manifest/OG URLs match the deployed host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_BUNNY_PULL_ORIGIN=https://video.nurawell.ai
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=654032

# Vercel / production: set the same NEXT_PUBLIC_* vars in the Vercel project.
# Bunny Stream → allowed embedding / referrer hostnames must include your deployment host
# (e.g. *.vercel.app and your custom domain), or the iframe can stay blank or error.

# --- AI (OpenRouter + DeepSeek) ---
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
# Optional: DeepSeek official API model for cron analysis (default: deepseek-chat, V3-class)
# DEEPSEEK_ANALYSIS_MODEL=deepseek-chat

# Cron: GET/POST /api/v1/ai/cron/master — Authorization: Bearer <CRON_SECRET> or ?secret=
CRON_SECRET=
# Optional tuning (defaults in route): CRON_INACTIVITY_DAYS=2 CRON_MAX_ANALYSIS_USERS=20 CRON_MAX_NUDGE_USERS=20 CRON_NUDGE_COOLDOWN_HOURS=48

