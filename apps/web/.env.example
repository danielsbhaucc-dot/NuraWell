# Copy to .env.local in this folder (apps/web) — Next.js only auto-loads env from the app directory.
# ⚠️ קובץ זה הוא טמפלייט בלבד. אסור להכניס פה credentials אמיתיים — הוא tracked ב-git!
# את ה-secrets האמיתיים יש למלא ב-.env.local (לוקאלי) או ב-Vercel Environment Variables (פרודקשן).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-jwt>
# גשר Ops: אחד מהשניים — מומלץ Legacy JWT service_role (טאב Legacy ב-API Keys). חלופה: sb_secret_ ב-SUPABASE_SECRET_KEY
# 🚨 service_role עוקף RLS — לעולם אל תקמיט את הערך האמיתי לגיט. רק שרת.
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-or-leave-empty>
# SUPABASE_SECRET_KEY=<sb_secret_...>  # חלופה ל-service_role; אחד מהשניים

# מקור האפליקציה הציבורית. בפרודקשן: next.config מגדיר ברירת מחדל ל־https://nurawell.vercel.app אם ריק.
# אפשר לעדכן כתובת קבועה גם מפאנל Ops → הגדרות אתר (site_settings ב־Supabase).
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_BUNNY_PULL_ORIGIN=https://video.nurawell.ai
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=654032

# Vercel / production: set the same NEXT_PUBLIC_* vars in the Vercel project.
# Bunny Stream → allowed embedding / referrer hostnames must include your deployment host
# (e.g. *.vercel.app and your custom domain), or the iframe can stay blank or error.

# --- Ops (פאנל ניהול) ---
# דומיין הפאנל (hostname בלבד; ללא https://). אופציונלי, אבל מומלץ בפרודקשן:
# NEXT_PUBLIC_OPS_HOSTNAME=ops.nurawell.ai
# כתובת מלאה (לבריג' login → ops):
# NEXT_PUBLIC_OPS_URL=https://ops.nurawell.ai
# preview ב-*.vercel.app כ-Ops — *רק* אם 1 *וגם* hostname מתחיל ב-prefix של הפרויקט.
# OPS_ALLOW_VERCEL_PREVIEW=0
# Prefix נדרש כשפיצ׳ר ה-preview דלוק. ברירת מחדל "nurawell-" (חוסם *.vercel.app זרים).
# OPS_VERCEL_PREVIEW_PROJECT_PREFIX=nurawell-

# --- AI (OpenRouter + DeepSeek + Groq) ---
# OpenRouter — ספק LLM הראשי לטקסט אמפתי לעין המשתמש (gpt-5-mini / gpt-5).
#   משמש את: הצ'אט, מנוע ההתראות (/api/workflows/notifications), ועוד.
OPENROUTER_API_KEY=
# DeepSeek — legacy ל-cron analytics ישנים.
DEEPSEEK_API_KEY=
# Groq — ספק ברירת המחדל ל"עבודה שחורה ברקע" עם LLaMA 4 (סיווגים,
# decision routing, סיכומים פנימיים). מהיר וזול ב-volume.
GROQ_API_KEY=
# Override אופציונלי של מודל ה-Groq (default: meta-llama/llama-4-scout-17b-16e-instruct)
# GROQ_BACKGROUND_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- AI Notification Engine (Upstash Workflow → OpenRouter gpt-5-mini) ---
# מנוע ההתראות מריץ 3 קרונים יומיים (08:00 / 13:00 / 20:00 IL) דרך
# POST /api/workflows/notifications. ה-LLM הוא gpt-5-mini (OpenRouter) —
# קצר, אמפתי, רגיש-טון. אם הקריאה נכשלת — fallback סטטי לכל NotificationState.
# Override אופציונלי של מודל ה-push (default: openai/gpt-5-mini)
# NOTIFICATION_ENGINE_MODEL=openai/gpt-5-mini

# --- AI Periodic Summary Engine ("Memory Pyramid") ---
# POST /api/summaries/generate מייצר סיכום תקופתי
# (daily/weekly/monthly/quarterly/semi_annual/annual) ושומר ב-`periodic_summaries`.
# Cascade: רמה גבוהה קוראת רק את הרמה שמתחתיה (חוסך טוקנים, 100% עקבי).
# מודל ראשי: gpt-5-mini דרך OpenRouter (אותו AI_MODELS.empathy של הצ'אט).
# Fallback: Llama 4 דרך Groq אם OpenRouter נופל.
# Override אופציונלי:
# SUMMARY_ENGINE_MODEL=openai/gpt-5-mini

# --- Upstash Vector — שני אינדקסים נפרדים ---
# אינדקס 1: זיכרון משתמש (namespace user-memory בקוד)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
# אינדקס 2: ידע מערכת / RAG (namespace system-knowledge; הזנה ב־/ops/system-rag-ingest, POST /api/chat)
# מימד 1536 (תואם openai/text-embedding-3-small).
UPSTASH_SYSTEM_VECTOR_REST_URL=
UPSTASH_SYSTEM_VECTOR_REST_TOKEN=
# שליפת RAG לפני GPT — כבה עם 0 אם צריך
AI_VECTOR_RAG_ENABLED=1
# כתיבת וקטורים ברקע אחרי הודעה — כבה עם 0 אם צריך
AI_VECTOR_INGEST_ENABLED=1

# --- Rate limiting (אופציונלי, אבל מומלץ מאוד לפרודקשן) ---
# בלי Upstash Redis המגבלה תפעל per-edge-instance (חוסם רק לולאות בצד הלקוח).
# עם Upstash Redis (אותו מסך ב-Upstash שבו QStash/Vector) — אכיפה מבוזרת אמיתית.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# מכסות לצ׳אט (ברירות מחדל: 20/דקה, 200/שעה לכל משתמש):
# AI_CHAT_RATE_LIMIT_PER_MIN=20
# AI_CHAT_RATE_LIMIT_PER_HOUR=200
# אופציונלי: אם מוגדר — POST /api/v1/ai/rag-self-test דורש כותרת x-rag-self-test-secret תואמת. בלי זה — מספיק session מחובר.
RAG_SELF_TEST_SECRET=
# Optional: DeepSeek official API model for cron analysis (default: deepseek-chat, V3-class)
# DEEPSEEK_ANALYSIS_MODEL=deepseek-chat

# --- Cron / Schedules — Upstash QStash בלבד ---
# נתיבים מתוזמנים (POST בלבד! GET סגור עם 405 כדי למנוע טריגר לא-מכוון):
#   POST /api/v1/ai/cron/master                                   — אחת ביום
#   POST /api/v1/ai/cron/habit-checkpoints?slot=morning|midday|evening — 3× ביום
#   POST /api/v1/ai/cron/onboarding-check-ins — כל 30 דק (זמנים אישיים מאלמוג)
#
# אימות נתמך:
#   (ראשי)   Upstash-Signature — QStash חותם את הבקשה; השרת מאמת מול QSTASH_CURRENT_SIGNING_KEY.
#   (גיבוי)  Authorization: Bearer <CRON_SECRET> — להפעלה ידנית מ-curl / Postman.
#
# מפתח QStash API — חובה לטריגר Workflows (Schedules 1–5)
QSTASH_TOKEN=
# מפתחות חתימה — מקבלים מ-Upstash Console → QStash → Signing Keys.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# אופציונלי לבדיקות ידניות וכ-fallback (לא חובה אם רק Upstash מתזמן):
CRON_SECRET=
# כיוונון (ברירות מחדל בקוד):
#   CRON_MAX_ANALYSIS_USERS=20 CRON_MAX_NUDGE_USERS=20 CRON_MAX_CELEBRATE_USERS=8 CRON_NUDGE_COOLDOWN_HOURS=48
#   CRON_MAX_HABIT_CHECKPOINT_TRIGGERS=350 (max 800)
#   CRON_MAX_ONBOARDING_CHECK_IN_TRIGGERS=200 (max 500)

# --- Email (Resend) — מייל ברכה מאלמוג אחרי אימות ---
# דומיין מאומת ב-Resend. ראה docs/EMAIL_AUTH_RESEND_SETUP.md
RESEND_API_KEY=
RESEND_FROM=NuraWell <onboarding@nurawell.ai>
# עיכוב לפני מייל ברכה (ברירת מחדל 3m)
# WELCOME_EMAIL_DELAY=3m

# --- Cloudflare R2 (Almog avatar) + CDN ---
# Custom domain that serves the R2 bucket (recommended). No trailing slash.
# Example production: https://cdn.nurawell.ai
NEXT_PUBLIC_CDN_URL=
# Worker path for image bucket (defaults to /images). Keep leading slash.
# NEXT_PUBLIC_CDN_IMAGES_PREFIX=/images
# Same URL allowed here instead of NEXT_PUBLIC_CDN_URL (optional).
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
# Server-only copy for API routes if you don’t rebuild the web bundle (optional).
# R2_PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# דלי תמונות (אווטאר אלמוג, תמונות תחנות במסע וכו'). בעתיד אפשר דלי נפרד לקבצים עם משתנה אחר.
R2_IMAGE_BUCKET_NAME=
# חיפוש תמונות לתחנות במסע (לוח ניהול בלבד):
PIXABAY_API_KEY=
PEXELS_API_KEY=
# תאימות לאחור — אם רק זה מוגדר, עדיין יעבוד:
# R2_BUCKET_NAME=

